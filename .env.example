# ── PromptEvo Environment ──────────────────────────────────────────────
# Copy to .env and adjust for your setup.

# ── API Keys (set only if using cloud providers) ───────────────────────
# OPENAI_API_KEY="sk-..."
# ANTHROPIC_API_KEY="sk-ant-..."
# GROQ_API_KEY="gsk_..."

# ── Development Mode ───────────────────────────────────────────────────
PROMPTEVO_DEV_DISABLE_AUTH=true
PROMPTEVO_CORS_ORIGINS=http://localhost:5173

# ── LLM Provider ───────────────────────────────────────────────────────
# Uses Ollama locally by default. Pull the required model first:
#   ollama pull gemma2:2b
INQUIRYER_PROVIDER=ollama
INQUIRYER_MODEL=gemma2:2b
OLLAMA_BASE_URL=http://localhost:11434

# ── Target Model ───────────────────────────────────────────────────────
ALLOWED_TARGET_MODELS=mock-target,gemma2

# ── Fast Debug Mode (skip expensive evaluations) ──────────────────────
FAST_DEBUG=true
DEBERTA_ENABLED=false
FAST_DEBUG_JUDGE_MODEL=gemma2:2b
FAST_DEBUG_JUDGE_PROVIDER=ollama
FAST_DEBUG_MAX_DOMAIN_PROBES=1
FAST_DEBUG_MAX_SCENARIOS=1

# ── Ollama Tuning ──────────────────────────────────────────────────────
OLLAMA_TIMEOUT_SECONDS=300
OLLAMA_CONNECT_TIMEOUT_SECONDS=10
OLLAMA_READ_TIMEOUT_SECONDS=300
OLLAMA_NUM_CTX=4096
OLLAMA_NUM_PREDICT=512
OLLAMA_KEEP_ALIVE=10m

# ── Logging ────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
